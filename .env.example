# GitReviewer 配置文件
# 复制此文件为 .env 后修改

# ------------------------------------------------------------------
# 服务器配置
# ------------------------------------------------------------------
SERVER_PORT=8000

# 工作区根目录（会话和 git 仓库存储位置）
WORKSPACE_ROOT=./workspaces

# 最大并行 review 任务数
MAX_CONCURRENT_REVIEWS=3

# API Key 认证（可选，调用方请求 GitReviewer 时需要携带，留空不启用认证）
API_KEY=

# Webhook 回调超时（秒）
WEBHOOK_TIMEOUT=30
